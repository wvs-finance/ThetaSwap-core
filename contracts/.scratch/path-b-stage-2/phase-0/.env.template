# Pair D Stage-2 Path B — environment variable template
# Copy to `.env` (NEVER commit `.env`; .gitignore must include path-b-stage-2/.env)
# Per `feedback_real_data_over_mocks` security caveat: real keys go in .env (uncommitted), .env.template is safe to commit

# ====================================================================
# REQUIRED — Alchemy free-tier RPC + receipts (spec §5)
# ====================================================================
# Sign up at https://www.alchemy.com (free tier; no credit card required)
# Per app: enable BOTH Ethereum mainnet AND Celo mainnet via dashboard
# Free-tier caps per spec §5.A: 30M CU/month, 25 req/sec sustained, 500 CU/sec rolling
ALCHEMY_API_KEY=your_alchemy_app_key_here

# ====================================================================
# OPTIONAL — Dune Analytics free-tier ad-hoc SQL (spec §5)
# ====================================================================
# Sign up at https://dune.com (free tier; ~2500 credits/month working assumption)
# Per spec §5: use only for ad-hoc analytical SQL where SQD primitives are inconvenient
DUNE_API_KEY=your_dune_api_key_here

# ====================================================================
# OPTIONAL — Block explorer ad-hoc verification keys (spec §5)
# ====================================================================
# Free tier works without keys; keys raise the rate limit to 5 req/s sustained
# NEVER for bulk extraction
CELOSCAN_API_KEY=your_celoscan_api_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here

