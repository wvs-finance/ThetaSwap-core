ETH_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/<YOUR_API_KEY>"

V4_POOL_MANAGER=""
ANGSTROM_MULTISIG=""
ANGSTROM_ADDRESS_TOKEN_ID=""

# ── Rev-5.2.1 Task 11.N.1 — COPM raw-transfers backfill fallback ───────────
#
# Alchemy Celo RPC API key — OPTIONAL, only consulted if the free Celo
# public RPC path (forno.celo.org + Ankr fallback) fails for Task 11.N.1.
# See plan Rev 5.2.1 Task 11.N.1 for fallback-trigger criteria:
#   contracts/docs/superpowers/plans/2026-04-20-remittance-surprise-implementation.md
#
# HALT-on-missing policy (Rev-5.2.1 CR hygiene finding): if the primary
# RPC path fails AND this variable is unset, the orchestration layer
# raises RuntimeError with a clear message rather than silently
# regressing to the 10-row sample. Populate this ONLY if you have
# confirmed the public RPC fallback trigger fired.
ALCHEMY_API_KEY=

# ── Rev-5.3 Task 11.N.1b — Resume-backfill alternative-path ladder ─────────
#
# The Task 11.N.1b orchestrator (resume_copm_transfers_backfill) walks a
# six-path ladder for blocks > checkpoint.last_completed_end_block. The
# first FOUR alternative paths each consult one of the env vars below;
# path-1 (Celo public RPC) needs no credentials; path-6 is a manual
# Dune-web CSV export with no env var.
#
# All four are OPTIONAL — leaving any of them unset causes the
# orchestrator to log "path-N SKIPPED (credential unset)" and fall
# through to the next path. HALT semantics fire ONLY when (a) all six
# paths fail/skip → orchestrator raises RuntimeError with
# X_D_STILL_INSUFFICIENT_PHASE_2, OR (b) a path's fetcher is invoked
# without its credential (defensive guard in the per-path fetchers).
# Plan reference (HALT-on-missing recovery-protocol bullet):
#   contracts/docs/superpowers/plans/2026-04-20-remittance-surprise-implementation.md
#   §"Task 11.N.1b: Resume missing-blocks backfill via alternative paths"
#   → "Recovery protocols" bullet 1 (X_D_STILL_INSUFFICIENT_PHASE_2)

# Path-2 — paid Alchemy Celo tier (alchemy_getAssetTransfers).
# Consulted ONLY when path-1 forno+Ankr exhaust without reaching the
# 110,069 ± 0.5 % target. HALT-on-missing: the orchestrator skips path-2
# silently if this is unset (the per-path fetcher itself raises if you
# call it directly with a None key — defensive). Cost expectation: NOT
# pinned in the plan per RC empirical (Alchemy pricing page does not
# surface the lowest paid tier reliably).
ALCHEMY_API_KEY_PAID=

# Path-3 — Covalent / GoldRush trial-tier API key.
# Consulted ONLY when paths 1+2 exhaust. Per RC empirical 2026-04-24:
# trial is 25,000 credits / 14 days, NOT a renewable monthly free
# tier — once expired the path skips automatically. HALT-on-missing:
# silent skip to path-4 if unset.
COVALENT_API_KEY=

# Path-4 — Flipside Crypto SQL REST API key.
# Consulted ONLY when paths 1-3 exhaust. Per RC empirical 2026-04-24:
# Celo is NOT explicitly listed on Flipside's chain-coverage pricing
# page; the path runs a describe-table probe on celo.core.fact_event_logs
# before the bulk SQL query and skips if the table is missing.
# HALT-on-missing: silent skip to path-5 if unset.
FLIPSIDE_API_KEY=

# Path-5 — Dune REST API direct (sidesteps MCP pagination limit).
# Consulted ONLY when paths 1-4 exhaust. Single execution of query
# 7369028 → poll → CSV download. Cost expectation: Dune community
# plan offers 25,000 monthly credits per RC empirical 2026-04-24
# (sufficient for one full-table pull). HALT-on-missing: silent skip
# to path-6 if unset.
DUNE_API_KEY=
