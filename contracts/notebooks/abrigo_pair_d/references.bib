% ── BPO transmission chain literature anchors ─────────────────────────────

% Mendieta-Muñoz 2017 — Colombia-specific premature-deindustrialization
% anchor. Traces Colombian deindustrialization to the 1990 Apertura under
% Gaviria. Primary literature anchor for the Y-side trap-tightening claim.
@article{mendietaMunoz2017colombia,
  author  = {Mendieta-Mu{\~n}oz, Iv{\'a}n},
  title   = {On the interaction between economic growth and business cycles in {C}olombia},
  journal = {Journal of Economic Structures},
  year    = {2017},
  volume  = {6},
  number  = {24},
  doi     = {10.1186/s40008-017-0084-9},
  note    = {Colombia premature-deindustrialization econometric anchor; traces structural transformation break to 1990 Apertura.}
}

% Rodrik 2016 — premature-deindustrialization framework. NBER WP 20935 +
% JEG 21(1). The framework that names the Colombian phenomenon Pair D is
% testing.
@article{rodrik2016premature,
  author  = {Rodrik, Dani},
  title   = {Premature Deindustrialization},
  journal = {Journal of Economic Growth},
  year    = {2016},
  volume  = {21},
  number  = {1},
  pages   = {1--33},
  doi     = {10.1007/s10887-015-9122-3},
  note    = {Framework for premature deindustrialization in late-industrializing economies; load-bearing for Pair D Y-side hypothesis.}
}

% McMillan & Rodrik 2011 — structural-transformation labor-allocation
% framework. NBER WP 17143. Provides the labor-share dynamics underlying
% the Y measurement choice (services share as trap-tightening indicator).
@techreport{mcmillanRodrik2011globalization,
  author      = {McMillan, Margaret S. and Rodrik, Dani},
  title       = {Globalization, Structural Change and Productivity Growth},
  institution = {National Bureau of Economic Research},
  year        = {2011},
  number      = {17143},
  type        = {NBER Working Paper},
  doi         = {10.3386/w17143}
}

