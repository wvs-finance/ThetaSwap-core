% ── B (Baumol cost-disease lineage) ────────────────────────────────────────

% Baumol-Bowen 1966 — canonical Baumol cost-disease text. Pre-DOI era;
% Twentieth Century Fund / The MIT Press monograph. Cited per spec §1
% transmission-chain anchor: low service-sector productivity growth →
% relative service-price inflation → US service-wage inflation pressure.
@book{baumolBowen1966performingArts,
  author    = {Baumol, William J. and Bowen, William G.},
  title     = {Performing Arts: The Economic Dilemma},
  year      = {1966},
  publisher = {Twentieth Century Fund},
  address   = {New York},
  note      = {Canonical Baumol cost-disease text. Pre-DOI; OCLC 380072.}
}

% Baumol 2006 — modern restatement of Baumol cost disease as part of NBER
% paper series. Spec §1 transmission-chain anchor (US service-sector
% productivity stagnation as the driver of US-Colombia service-wage
% arbitrage).
@techreport{baumol2006costDisease,
  author      = {Baumol, William J.},
  title       = {Children of Performing Arts, the Economic Dilemma: The Climbing Costs of Health Care and Education},
  institution = {National Bureau of Economic Research},
  type        = {NBER Working Paper},
  number      = {12218},
  year        = {2006},
  doi         = {10.3386/w12218}
}

% Beerepoot-Hendriks 2013 — Philippines BPO direct-mechanism validation
% (dead-end-jobs framing). Spec §1 BPO-comparable framework anchor; cited
% as the canonical Philippine analog used to ground the Colombian BPO
% young-worker trap hypothesis. Service Industries Journal indexes the
% article via Taylor & Francis with DOI.
@article{beerepootHendriks2013deadEndJobs,
  author  = {Beerepoot, Niels and Hendriks, Mara},
  title   = {Employability of Offshore Service-Sector Workers in the {Philippines}: Dead-End Jobs?},
  journal = {The Service Industries Journal},
  year    = {2013},
  volume  = {33},
  number  = {11},
  pages   = {1135--1156},
  doi     = {10.1080/02642069.2013.747514}
}

